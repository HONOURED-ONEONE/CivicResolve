# CivicResolve Decentralized Architecture .env.example

# Service Ports
PORT_CASE_ORCHESTRATOR=3001
PORT_INTELLIGENCE=8000
PORT_AI_ADVISORY=3002
PORT_CONNECTOR=3003
PORT_SLA_STATUS=3004
PORT_GOVERNANCE=3005

# Service URLs
INTELLIGENCE_SERVICE_URL=http://localhost:8000
AI_ADVISORY_SERVICE_URL=http://localhost:3002
CONNECTOR_SERVICE_URL=http://localhost:3003
SLA_STATUS_SERVICE_URL=http://localhost:3004
GOVERNANCE_PLATFORM_URL=http://localhost:3005

# Feature Flags
ENABLE_AI_ADVISORY=true
ENABLE_VISION_EXTRACT=true
ENABLE_DRAFT_ASSIST=true
ENABLE_SEARCH_CITATIONS=true

# AI Providers (stub, openai, anthropic)
SEARCH_PROVIDER=stub
VISION_PROVIDER=stub
REASONING_PROVIDER=stub

# API Keys (leave empty for stubs)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
